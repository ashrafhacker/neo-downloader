# ===== Required: Set a strong admin password =====
# Password is stored securely via werkzeug hashing.
# Run: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password-here'))"
# to generate a hash, then set ADMIN_PASSWORD to that hash.
ADMIN_PASSWORD=

# ===== Flask secret key (generate a random one) =====
# Run: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ===== MongoDB (optional) =====
# Uncomment and set your MongoDB connection string for replication logging.
# MONGO_URI=mongodb://localhost:27017/media_downloader

# ===== Webhook URL (optional) =====
# Receive real-time POST webhooks on every download and capture event.
# WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# ===== TeraBox Cookie (optional) =====
# Cookie string for TeraBox downloads.
# TERABOX_COOKIE=

# ===== Server Config =====
PORT=5000
FLASK_DEBUG=0
